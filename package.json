{
  "name": "kiro-for-cc",
  "displayName": "Kiro for Agent Code",
  "description": "Spec-driven development with Claude Code, Codex, DeepSeek, GLM, and custom agents - inspired by Kiro",
  "version": "0.2.9",
  "publisher": "heisebaiyun",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/notdp/kiro-for-cc"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kfc",
          "title": "Kiro for Agent Code",
          "icon": "./icons/kiro.svg"
        }
      ]
    },
    "views": {
      "kfc": [
        {
          "id": "kfc.views.specExplorer",
          "name": "Specs",
          "when": "!(workbenchState == empty || workspaceFolderCount == 0) && config.kfc.views.specs.visible"
        },
        {
          "id": "kfc.views.agentsExplorer",
          "name": "Agents",
          "when": "!(workbenchState == empty || workspaceFolderCount == 0) && config.kfc.views.agents.visible"
        },
        {
          "id": "kfc.views.steeringExplorer",
          "name": "Steering",
          "when": "!(workbenchState == empty || workspaceFolderCount == 0) && config.kfc.views.steering.visible"
        },
        {
          "id": "kfc.views.mcpServerStatus",
          "name": "MCP Servers",
          "when": "!(workbenchState == empty || workspaceFolderCount == 0) && config.kfc.views.mcp.visible"
        },
        {
          "id": "kfc.views.hooksStatus",
          "name": "Hooks",
          "when": "!(workbenchState == empty || workspaceFolderCount == 0) && config.kfc.views.hooks.visible"
        },
        {
          "id": "kfc.views.overview",
          "name": "Settings",
          "visibility": "collapsed",
          "when": "!(workbenchState == empty || workspaceFolderCount == 0) && config.kfc.views.settings.visible"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "kfc.views.overview",
        "contents": "Configure Kiro agent providers\n\n[$(gear) Open Settings](command:kfc.settings.open)\n[$(question) Help](command:kfc.help.open)"
      },
      {
        "view": "kfc.views.specExplorer",
        "contents": "Build complex features with structured planning\n\n[$(plus) Create New Spec](command:kfc.spec.create)\n\n[$(sparkle) Create New Spec With Agents](command:kfc.spec.createWithAgents)"
      },
      {
        "view": "kfc.views.hooksStatus",
        "contents": "Automate repetitive tasks with smart triggers"
      },
      {
        "view": "kfc.views.steeringExplorer",
        "contents": "[$(globe) Create User Rule](command:kfc.steering.createUserRule)\n\n[$(root-folder) Create Project Rule](command:kfc.steering.createProjectRule)"
      },
      {
        "view": "kfc.views.mcpServerStatus",
        "contents": "Connect to external tools and services\nConfigure extension MCP servers in Kiro settings"
      }
    ],
    "commands": [
      {
        "command": "kfc.spec.create",
        "title": "Create New Spec",
        "category": "Kiro for Agent Code",
        "icon": "$(plus)"
      },
      {
        "command": "kfc.spec.createWithAgents",
        "title": "New Spec with Agents",
        "category": "Kiro for Agent Code",
        "icon": "$(sparkle)"
      },
      {
        "command": "kfc.steering.create",
        "title": "Create Custom Steering",
        "category": "Kiro for Agent Code",
        "icon": "$(plus)"
      },
      {
        "command": "kfc.steering.generateInitial",
        "title": "Init Steering",
        "category": "Kiro for Agent Code",
        "icon": "$(sparkle)"
      },
      {
        "command": "kfc.steering.refine",
        "title": "Refine Steering",
        "category": "Kiro for Agent Code",
        "icon": "$(sparkle)"
      },
      {
        "command": "kfc.spec.delete",
        "title": "Delete Spec",
        "category": "Kiro for Agent Code",
        "icon": "$(trash)"
      },
      {
        "command": "kfc.steering.delete",
        "title": "Delete Steering",
        "category": "Kiro for Agent Code",
        "icon": "$(trash)"
      },
      {
        "command": "kfc.steering.createUserRule",
        "title": "Create User Rule",
        "category": "Kiro for Agent Code",
        "icon": "$(globe)"
      },
      {
        "command": "kfc.steering.createProjectRule",
        "title": "Create Project Rule",
        "category": "Kiro for Agent Code",
        "icon": "$(root-folder)"
      },
      {
        "command": "kfc.hooks.refresh",
        "title": "Refresh Hooks",
        "category": "Kiro for Agent Code",
        "icon": "$(refresh)"
      },
      {
        "command": "kfc.mcp.refresh",
        "title": "Refresh MCP Status",
        "category": "Kiro for Agent Code",
        "icon": "$(refresh)"
      },
      {
        "command": "kfc.settings.open",
        "title": "Kiro Settings",
        "category": "Kiro for Agent Code",
        "icon": "$(gear)"
      },
      {
        "command": "kfc.checkForUpdates",
        "title": "Check for Updates",
        "category": "Kiro for Agent Code",
        "icon": "$(sync)"
      },
      {
        "command": "kfc.spec.refresh",
        "title": "Refresh Specs",
        "category": "Kiro for Agent Code",
        "icon": "$(refresh)"
      },
      {
        "command": "kfc.steering.refresh",
        "title": "Refresh Steering",
        "category": "Kiro for Agent Code",
        "icon": "$(refresh)"
      },
      {
        "command": "kfc.agents.refresh",
        "title": "Refresh Agents",
        "category": "Kiro for Agent Code",
        "icon": "$(refresh)"
      },
      {
        "command": "kfc.help.open",
        "title": "Kiro Help",
        "category": "Kiro for Agent Code",
        "icon": "$(question)"
      },
      {
        "command": "kfc.menu.open",
        "title": "Kiro Menu",
        "category": "Kiro for Agent Code",
        "icon": "$(ellipsis)"
      },
      {
        "command": "kfc.permission.check",
        "title": "Check Permission Status",
        "category": "Kiro for Agent Code",
        "icon": "$(info)"
      },
      {
        "command": "kfc.permission.reset",
        "title": "Reset Permissions",
        "category": "Kiro for Agent Code",
        "icon": "$(debug-restart)"
      },
      {
        "command": "kfc.spec.implTask",
        "title": "Implement Task",
        "category": "Kiro for Agent Code"
      },
      {
        "command": "kfc.spec.implAllTasks",
        "title": "Implement All Spec Tasks",
        "category": "Kiro for Agent Code"
      },
      {
        "command": "kfc.spec.markTaskDone",
        "title": "Mark Spec Task Done",
        "category": "Kiro for Agent Code"
      },
      {
        "command": "kfc.spec.viewTaskSession",
        "title": "View Spec Task AI Session",
        "category": "Kiro for Agent Code"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "kfc.menu.open",
          "when": "view == kfc.views.overview",
          "group": "navigation"
        },
        {
          "command": "kfc.spec.create",
          "when": "view == kfc.views.specExplorer",
          "group": "navigation@1"
        },
        {
          "command": "kfc.spec.createWithAgents",
          "when": "view == kfc.views.specExplorer",
          "group": "navigation@2"
        },
        {
          "command": "kfc.spec.refresh",
          "when": "view == kfc.views.specExplorer",
          "group": "navigation@3"
        },
        {
          "command": "kfc.steering.generateInitial",
          "when": "view == kfc.views.steeringExplorer",
          "group": "navigation@2"
        },
        {
          "command": "kfc.steering.create",
          "when": "view == kfc.views.steeringExplorer",
          "group": "navigation@1"
        },
        {
          "command": "kfc.steering.refresh",
          "when": "view == kfc.views.steeringExplorer",
          "group": "navigation@3"
        },
        {
          "command": "kfc.mcp.refresh",
          "when": "view == kfc.views.mcpServerStatus",
          "group": "navigation"
        },
        {
          "command": "kfc.hooks.refresh",
          "when": "view == kfc.views.hooksStatus",
          "group": "navigation"
        },
        {
          "command": "kfc.agents.refresh",
          "when": "view == kfc.views.agentsExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "kfc.spec.delete",
          "when": "view == kfc.views.specExplorer && viewItem == spec",
          "group": "7_modification"
        },
        {
          "command": "kfc.steering.refine",
          "when": "view == kfc.views.steeringExplorer && viewItem == steering-document",
          "group": "inline"
        },
        {
          "command": "kfc.steering.delete",
          "when": "view == kfc.views.steeringExplorer && viewItem == steering-document",
          "group": "7_modification"
        }
      ],
      "commandPalette": [
        {
          "command": "kfc.spec.create"
        },
        {
          "command": "kfc.steering.create",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "kfc.checkForUpdates"
        }
      ]
    },
    "configuration": {
      "title": "Kiro for Agent Code",
      "properties": {
        "kfc.claudePath": {
          "type": "string",
          "default": "claude",
          "description": "Legacy path to Claude Code CLI executable. Prefer kfc.providers.claude.command."
        },
        "kfc.agent.provider": {
          "type": "string",
          "default": "claude",
          "enum": [
            "claude",
            "codex",
            "deepseek",
            "glm",
            "custom"
          ],
          "description": "Active agent provider used for spec, steering, and task execution."
        },
        "kfc.agent.model": {
          "type": "string",
          "default": "",
          "description": "Optional model identifier for future API-backed runtimes."
        },
        "kfc.providers.claude.command": {
          "type": "string",
          "default": "claude",
          "description": "Claude Code CLI command."
        },
        "kfc.providers.codex.command": {
          "type": "string",
          "default": "codex",
          "description": "Codex/OpenAI CLI command."
        },
        "kfc.providers.codex.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional arguments passed before the prompt for the Codex/OpenAI CLI."
        },
        "kfc.providers.deepseek.command": {
          "type": "string",
          "default": "deepseek",
          "description": "DeepSeek CLI command."
        },
        "kfc.providers.deepseek.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional arguments passed before the prompt for the DeepSeek CLI."
        },
        "kfc.providers.glm.command": {
          "type": "string",
          "default": "glm",
          "description": "GLM/Z.AI CLI command."
        },
        "kfc.providers.glm.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional arguments passed before the prompt for the GLM/Z.AI CLI."
        },
        "kfc.providers.custom.displayName": {
          "type": "string",
          "default": "Custom Agent",
          "description": "Display name for the custom agent provider."
        },
        "kfc.providers.custom.command": {
          "type": "string",
          "default": "agent",
          "description": "Custom agent CLI command."
        },
        "kfc.providers.custom.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional arguments passed before the prompt for the custom CLI."
        },
        "kfc.providers.custom.commandTemplate": {
          "type": "string",
          "default": "{command} {args} \"{prompt}\"",
          "description": "Custom command template. Tokens: {command}, {args}, {model}, {prompt}."
        },
        "kfc.mcp.customServers": {
          "type": "array",
          "default": [],
          "description": "Extension-level custom MCP servers available to non-Claude providers.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["stdio", "command", "sse", "http"]
              },
              "command": { "type": "string" },
              "args": {
                "type": "array",
                "items": { "type": "string" }
              },
              "env": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "url": { "type": "string" },
              "headers": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "description": { "type": "string" }
            }
          }
        },
        "kfc.spec.autoMarkTaskDone": {
          "type": "boolean",
          "default": true,
          "description": "Automatically mark a spec task done after the active agent completes and a follow-up model verification confirms completion."
        },
        "kfc.spec.autoMarkTaskDoneMinConfidence": {
          "type": "number",
          "default": 0.8,
          "minimum": 0,
          "maximum": 1,
          "description": "Minimum verification confidence required before automatically marking a spec task done."
        },
        "kfc.autoRefreshSpecs": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh specs when requirements are saved"
        },
        "kfc.showWelcomeMessage": {
          "type": "boolean",
          "default": true,
          "description": "Show welcome message on startup"
        },
        "kfc.views.specs.visible": {
          "type": "boolean",
          "default": true,
          "description": "Show Specs view"
        },
        "kfc.views.agents.visible": {
          "type": "boolean",
          "default": true,
          "description": "Show Agents view"
        },
        "kfc.views.hooks.visible": {
          "type": "boolean",
          "default": true,
          "description": "Show Agent Hooks view"
        },
        "kfc.views.steering.visible": {
          "type": "boolean",
          "default": true,
          "description": "Show Agent Steering view"
        },
        "kfc.views.mcp.visible": {
          "type": "boolean",
          "default": true,
          "description": "Show MCP Servers view"
        },
        "kfc.views.settings.visible": {
          "type": "boolean",
          "default": false,
          "description": "Show Settings view"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package-web",
    "compile": "npm run build-prompts && tsc -p ./",
    "watch": "concurrently \"tsc -watch -p ./\" \"node scripts/watch-prompts.js\"",
    "package": "vsce package",
    "build-prompts": "node scripts/build-prompts.js",
    "compile-web": "webpack --mode development",
    "watch-web": "webpack --mode development --watch",
    "package-web": "npm run build-prompts && webpack --mode production --devtool hidden-source-map",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/glob": "^8.1.0",
    "@types/handlebars": "^4.0.40",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.x",
    "@types/vscode": "^1.84.0",
    "concurrently": "^9.2.0",
    "copy-webpack-plugin": "^13.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.3.0",
    "vsce": "^2.15.0",
    "webpack": "^5.100.2",
    "webpack-cli": "^6.0.1"
  }
}
